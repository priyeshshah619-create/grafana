{
  "dashboard": {
    "id": null,
    "title": "AWS Infrastructure Health",
    "tags": ["aws", "sns"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "type": "timeseries",
        "title": "SNS Messages Published",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "datasource": { "type": "cloudwatch", "uid": "grafana-cloudwatch-datasource" },
        "targets": [
          {
            "namespace": "AWS/SNS",
            "metricName": "NumberOfMessagesPublished",
            "region": "us-east-1",
            "statistic": "Sum",
            "period": "300",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "SNS Messages Failed",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "datasource": { "type": "cloudwatch", "uid": "grafana-cloudwatch-datasource" },
        "targets": [
          {
            "namespace": "AWS/SNS",
            "metricName": "NumberOfMessagesFailed",
            "region": "us-east-1",
            "statistic": "Sum",
            "period": "300",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "type": "gauge",
        "title": "Total SNS Success Rate",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
        "datasource": { "type": "cloudwatch", "uid": "grafana-cloudwatch-datasource" },
        "targets": [
          {
            "namespace": "AWS/SNS",
            "metricName": "NumberOfNotificationsFailed",
            "region": "us-east-1",
            "statistic": "Sum",
            "period": "300",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}
