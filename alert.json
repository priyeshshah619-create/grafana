{
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "order-service-alerts",
      "folder": "Order Service Alerts",
      "interval": "1m",
      "rules": [
        {
          "uid": "order-service-error-rate",
          "title": "Order Service - Error Rate Breach",
          "condition": "C",
          "data": [
            {
              "refId": "A",
              "relativeTimeRange": {
                "from": 300,
                "to": 0
              },
              "datasourceUid": "ffkcyaybrfxtsf",
              "model": {
                "expression": "filter @message like /ERROR/ | stats count() as errorCount by bin(1m)",
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "logGroups": [
                  {
                    "accountId": "882352060841",
                    "arn": "arn:aws:logs:us-east-1:882352060841:log-group:/app/order-service:*",
                    "name": "/app/order-service"
                  }
                ],
                "queryLanguage": "CWLI",
                "queryMode": "Logs",
                "refId": "A",
                "region": "us-east-1"
              }
            },
            {
              "refId": "B",
              "datasourceUid": "__expr__",
              "model": {
                "expression": "A",
                "type": "reduce",
                "reducer": "last",
                "refId": "B"
              }
            },
            {
              "refId": "C",
              "datasourceUid": "__expr__",
              "model": {
                "expression": "B",
                "type": "threshold",
                "refId": "C",
                "conditions": [
                  {
                    "evaluator": {
                      "type": "gt",
                      "params": [0]
                    },
                    "operator": {
                      "type": "and"
                    }
                  }
                ]
              }
            }
          ],
          "noDataState": "NoData",
          "execErrState": "Error",
          "for": "2m",
          "isPaused": false,
          "notification_settings": {
            "receiver": "SNS - Grafana Alerts"
          }
        }
      ]
    }
  ]
}
